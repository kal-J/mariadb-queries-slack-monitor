# .env  —  chmod 600 this file
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=monitor
DB_PASSWORD=your_password_here

SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Slow digests: lifetime avg from performance_schema (since server start).
# Alerts fire only when exec count, max, or avg changes — not on a fixed repeat timer.
SLOW_THRESHOLD_SEC=2.0
LONG_RUNNING_SEC=30.0
MIN_EXEC_COUNT=5
POLL_INTERVAL_SEC=300
# Used for long-running query dedup only (slow digests are change-only).
STATE_TTL_SEC=3600
STATE_FILE=/var/lib/mariadb-monitor/state.json
